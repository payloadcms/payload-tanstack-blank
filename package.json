{
  "name": "payload-tanstack-blank",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" payload build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation vite dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation vite dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation vite preview",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@payloadcms/db-sqlite": "4.0.0-internal.7b031c8",
    "@payloadcms/graphql": "4.0.0-internal.7b031c8",
    "@payloadcms/plugin-mcp": "4.0.0-internal.7b031c8",
    "@payloadcms/richtext-lexical": "4.0.0-internal.7b031c8",
    "@payloadcms/tanstack-start": "4.0.0-internal.7b031c8",
    "@payloadcms/ui": "4.0.0-internal.7b031c8",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-start": "1.168.26",
    "cross-env": "10.1.0",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "payload": "4.0.0-internal.7b031c8",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sass": "^1.101.0",
    "sharp": "0.34.2",
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@testing-library/react": "16.3.0",
    "@types/node": "24.12.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitejs/plugin-rsc": "^0.5.26",
    "eslint": "^9.16.0",
    "jsdom": "28.0.0",
    "prettier": "^3.4.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.1.6"
  },
  "engines": {
    "node": ">=24.15.0",
    "pnpm": "^9 || ^10 || ^11"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
